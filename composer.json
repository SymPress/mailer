{
    "name": "sympress/mailer",
    "description": "Core Symfony Mailer powered WordPress mail plugin for the SymPress kernel.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Brian Schäffner",
            "email": "brian.schaeffner@sympress.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "sympress/assets": "dev-main",
        "sympress/kernel": "dev-main"
    },
    "require-dev": {
        "brain/monkey": "^2",
        "friendsofphp/php-cs-fixer": "^3.94",
        "mockery/mockery": "^1.6",
        "php-stubs/wordpress-stubs": ">=7.0@stable",
        "symfony/var-dumper": "^8.1",
        "sympress/qa": "dev-main"
    },
    "suggest": {
        "symfony/amazon-mailer": "Adds Amazon SES API and SMTP DSN support.",
        "symfony/brevo-mailer": "Adds Brevo API and SMTP DSN support.",
        "symfony/google-mailer": "Adds Gmail SMTP DSN support for development and small sites.",
        "symfony/mailgun-mailer": "Adds Mailgun API and SMTP DSN support.",
        "symfony/mailjet-mailer": "Adds Mailjet API and SMTP DSN support.",
        "symfony/mailer-send-mailer": "Adds MailerSend API and SMTP DSN support.",
        "symfony/mailtrap-mailer": "Adds Mailtrap live and sandbox DSN support.",
        "symfony/microsoft-graph-mailer": "Adds Microsoft Graph DSN support for Outlook and Microsoft 365.",
        "symfony/postmark-mailer": "Adds Postmark API and SMTP DSN support.",
        "symfony/resend-mailer": "Adds Resend API and SMTP DSN support.",
        "symfony/sendgrid-mailer": "Adds SendGrid API and SMTP DSN support."
    },
    "autoload": {
        "psr-4": {
            "SymPress\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SymPress\\Mailer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": [
            "Composer\\Config::disableProcessTimeout",
            "qa cs"
        ],
        "cs:fix": [
            "Composer\\Config::disableProcessTimeout",
            "qa cs:fix"
        ],
        "static-analysis": [
            "Composer\\Config::disableProcessTimeout",
            "qa static-analysis"
        ],
        "tests": [
            "Composer\\Config::disableProcessTimeout",
            "qa tests"
        ],
        "test": [
            "@tests"
        ],
        "qa": [
            "@cs",
            "@static-analysis",
            "@tests"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "kernel": {
            "bundle": "SymPress\\Mailer\\MailerBundle",
            "entry": "mailer/mailer.php"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
